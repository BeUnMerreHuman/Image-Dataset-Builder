import os
import shutil
from pathlib import Path
from dotenv import load_dotenv

load_dotenv("../.env")
BASE_DOWNLOAD_DIR = os.getenv("BASE_DOWNLOAD_DIR", "downloads")
DATASET_DIR = os.getenv("DATASET_DIR", "dataset")
PARQUET_PATH = Path(f"{DATASET_DIR}.parquet")

rule all:
    input:
        "Trash/cleanup.log"

rule download_images:
    input:
        "keywords.txt",
        "../.env"
    output:
        "downloads.csv", 
        temp("progress.json"),
        directory(BASE_DOWNLOAD_DIR)
    shell:
        "python ImageDownloader.py"

rule clean_data:
    input:
        "downloads.csv",
        data_dir = BASE_DOWNLOAD_DIR
    output:
        temp("clean_data.log")
    shell:
        "python DataCleaner.py {input.data_dir} > clean_data.log"

rule select_images:
    input:
        "clean_data.log",
    output:
        "selected_images.csv",
        temp("processed_labels.csv") 
    message:
        "Opening GUI for image selection. Pipeline is paused until you save and close the window."
    shell:
        "python ImageSelector.py"

rule move_files:
    input:
        "selected_images.csv"
    output:
        temp("moved_files.log")
    shell:
        "python MoveFiles.py > moved_files.log"

rule create_metadata:
    input:
        "moved_files.log",
        "downloads.csv", 
        "selected_images.csv" 
    output:
        "metadata.csv" 
    shell:
        "python MetadataCreator.py"

rule edit_labels:
    input:
        "metadata.csv",
        "moved_files.log"
    output:
        temp("edited_labels.log")
    message:
        "Opening GUI for label editing. Pipeline is paused until you save and close the window."
    shell:
        "python LabelEditor.py > edited_labels.log"

rule build_dataset:
    input:
        "metadata.csv",
        "edited_labels.log"
    output:
        PARQUET_PATH
    shell:
        "python DatasetCreator.py"

rule clean_parquet:
    input:
        "edited_labels.log",
        data_dir = PARQUET_PATH
    output:
        temp("clean_parquet.log")
    shell:
        "python DataCleaner.py {input.data_dir} > clean_parquet.log"

rule view_dataset:
    input:
        PARQUET_PATH,
        "clean_parquet.log"
    output:
        temp("viewed_dataset.log")
    message:
        "Opening GUI for Dataset Viewing. Pipeline is paused until you save and close the window."
    shell:
        "python DatasetViewer.py > viewed_dataset.log"

rule export_dataset:
    input:
        PARQUET_PATH,
        "viewed_dataset.log"
    output:
        os.path.join("..", os.path.basename(str(PARQUET_PATH)))
    run:
        shutil.copy(input[0], output[0])

rule cleanup:
    input:
        os.path.join("..", os.path.basename(str(PARQUET_PATH))),
        "viewed_dataset.log"
    output:
        temp("Trash/cleanup.log")
    params:
        dl_dir=BASE_DOWNLOAD_DIR,
        ds_dir=DATASET_DIR,
        do_dir="output",
        csv_files=["downloads.csv", "selected_images.csv", "metadata.csv"] 
    run:
        dirs_to_move = [params.dl_dir, params.ds_dir, params.do_dir]
        for d in dirs_to_move:
            if os.path.exists(d):
                dest_dir = os.path.join("Trash", os.path.basename(d))
                if os.path.exists(dest_dir):
                    shutil.rmtree(dest_dir)
                shutil.move(d, "Trash/")
        
        for f in params.csv_files:
            if os.path.exists(f):
                dest_file = os.path.join("Trash", f)
                if os.path.exists(dest_file):
                    os.remove(dest_file)
                shutil.move(f, "Trash/")

        with open(output[0], "w") as log_file:
            log_file.write("Cleanup completed successfully.\n")